// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  SSLCOMMERZ
  CASH
  CARD
  BKASH
  NAGAD
  ROCKET
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  POS_SALE
}

enum OrderChannel {
  ONLINE
  POS
}

enum CustomerSegment {
  VIP
  REGULAR
  NEW
  INACTIVE
}

enum StockTransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum BranchType {
  WAREHOUSE
  RETAIL
  OFFICE
  DISTRIBUTION
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  COLOR_MISMATCH
  NOT_AS_DESCRIBED
  CUSTOMER_CHANGED_MIND
  DAMAGED_IN_TRANSIT
  EXPIRED
  QUALITY_ISSUE
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RETURNED_RECEIVED
  INSPECTED
  REFUND_PROCESSED
  CLOSED
}

// ─────────────────────────────────────────────────────────────
// USER TYPES
// Role codes are business-driven and mapped to permissions in code.
// ─────────────────────────────────────────────────────────────

model UserType {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(20)
  name        String    @db.VarChar(120)

  users       User[]

  @@map("user_type")
}

// ─────────────────────────────────────────────────────────────
// USERS
// Application users authenticated via email/password and user_type.
// ─────────────────────────────────────────────────────────────

model User {
  id             Int        @id @default(autoincrement())
  keycloakId     String?    @unique
  email          String     @unique
  password       String?    @db.VarChar(255)
  userTypeId     Int?       @map("user_type_id")
  userType       UserType?  @relation(fields: [userTypeId], references: [id], onDelete: Restrict)
  firstName      String?
  lastName       String?
  phone          String?
  address        String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer        Customer?
  orders          Order[]        @relation("StaffOrders")
  auditLogs       AuditLog[]     @relation("CreatedBy")
  stockTransfers  StockTransfer[]
  refreshTokens   RefreshToken[]
  
  // RBAC relationships
  userRoles       UserRole_Model[]
  userBranches    UserBranch[]
  assignedRoles   RoleAssignment[]
  userModules     UserModule[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// REFRESH TOKENS
// Stored as SHA-256 hashes. Rotation is one-time use.
// ─────────────────────────────────────────────────────────────

model RefreshToken {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash") @db.Text
  expiresAt   DateTime  @map("expires_at")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([expiresAt])
  @@index([revoked])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// CUSTOMERS
// Extended profile for users with CUSTOMER role.
// ─────────────────────────────────────────────────────────────

model Customer {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  phone           String?
  dateOfBirth     DateTime?
  gender          String?
  defaultAddress  String?
  city            String?
  postalCode      String?
  country         String    @default("Bangladesh")
  loyaltyPoints   Int       @default(0)
  totalSpent      Decimal   @default(0) @db.Decimal(12,2)
  totalOrders     Int       @default(0)
  lastOrderAt     DateTime?
  segment         CustomerSegment @default(NEW)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders          Order[]
  wishlist        Wishlist[]

  @@map("customers")
}

// ─────────────────────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────────────────────

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
  skuSetting  SKUSetting?
  branchId    Int?
  branch      Branch?   @relation(fields: [branchId], references: [id])

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────

enum UnitType {
  PIECE
  WEIGHT
}

model Product {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  description     String?
  shortDescription String?
  price           Decimal   @db.Decimal(10,2)
  compareAtPrice  Decimal?  @db.Decimal(10,2)
  costPrice       Decimal?  @db.Decimal(10,2)
  sku             String    @unique
  barcode         String?
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id])
  images          String[]
  isFeatured      Boolean   @default(false)
  isActive        Boolean   @default(true)
  tags            String[]
  weight          Decimal?  @db.Decimal(8,2)

  // Unit & Size support
  unitType        UnitType  @default(PIECE)
  unitLabel       String    @default("pc")  // e.g. "pc", "kg", "g", "ml", "L"

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sizes           ProductSize[]
  inventories     Inventory[]
  analytics       ProductAnalytics?
  orderItems      OrderItem[]
  manualSaleItems ManualSaleItem[]
  manualReturnItems ManualReturnItem[]
  supplierTransactionItems SupplierTransactionItem[]
  wishlist        Wishlist[]
  transfers       StockTransfer[]
  skuHistory      SKUHistory[]

  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT SIZES
// Optional sizes per product. Each size has its own image.
// ─────────────────────────────────────────────────────────────

model ProductSize {
  id          Int       @id @default(autoincrement())
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String    // e.g. "S", "M", "L", "XL", "100ml", "250ml"
  sortOrder   Int       @default(0)
  imageUrl    String?   // Each size can have its own image
  priceOverride Decimal? @db.Decimal(10,2) // Optional price override for this size
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, name])
  @@index([productId])
  @@map("product_sizes")
}

// ─────────────────────────────────────────────────────────────
// MANUAL SALES
// Staff POS/manual multi-item sales recorded from dashboard.
// ─────────────────────────────────────────────────────────────

model ManualSale {
  id          Int              @id @default(autoincrement())
  saleNumber  String           @unique
  totalAmount Decimal          @db.Decimal(12,2)
  totalQty    Int
  branchId    Int?
  branchName  String?
  note        String?
  soldBy      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  items       ManualSaleItem[]

  @@index([createdAt])
  @@index([branchId, createdAt])

  @@map("manual_sales")
}

model ManualSaleItem {
  id                 Int        @id @default(autoincrement())
  manualSaleId       Int
  manualSale         ManualSale @relation(fields: [manualSaleId], references: [id], onDelete: Cascade)
  productId          Int
  product            Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  productSkuSnapshot  String
  quantity           Int
  unitPrice          Decimal    @db.Decimal(10,2)
  lineTotal          Decimal    @db.Decimal(12,2)
  sizeName           String?    // Snapshot of size at time of sale
  createdAt          DateTime   @default(now())

  @@index([manualSaleId])
  @@index([productId])
  @@map("manual_sale_items")
}

// ─────────────────────────────────────────────────────────────
// MANUAL RETURNS
// Staff warehouse returns recorded from dashboard.
// ─────────────────────────────────────────────────────────────

model ManualReturn {
  id            Int                @id @default(autoincrement())
  returnNumber  String             @unique
  totalAmount   Decimal            @db.Decimal(12,2)
  totalQty      Int
  branchId      Int?
  branchName    String?
  reason        String?
  returnedBy    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  items         ManualReturnItem[]

  @@index([createdAt])
  @@index([branchId, createdAt])
  @@map("manual_returns")
}

model ManualReturnItem {
  id                  Int          @id @default(autoincrement())
  manualReturnId      Int
  manualReturn        ManualReturn @relation(fields: [manualReturnId], references: [id], onDelete: Cascade)
  productId           Int
  product             Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  productSkuSnapshot  String
  quantity            Int
  unitPrice           Decimal      @db.Decimal(10,2)
  lineTotal           Decimal      @db.Decimal(12,2)
  sizeName            String?
  createdAt           DateTime     @default(now())

  @@index([manualReturnId])
  @@index([productId])
  @@map("manual_return_items")
}

// ─────────────────────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────────────────────

model Supplier {
  id              Int       @id @default(autoincrement())
  name            String
  email           String?
  phone           String?
  address         String?
  rotationDays    Int?      // Product rotation period in days
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    SupplierTransaction[]

  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────
// SUPPLIER TRANSACTIONS
// Records of money/items exchanged with suppliers.
// Does NOT affect inventory — user updates inventory separately.
// ─────────────────────────────────────────────────────────────

enum SupplierTransactionDirection {
  DUE_TO_SUPPLIER   // We owe the supplier
  DUE_TO_US         // Supplier owes us (refund/credit)
}

model SupplierTransaction {
  id              Int                          @id @default(autoincrement())
  supplierId      Int
  supplier        Supplier                     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branchId        Int?
  branchName      String?
  direction       SupplierTransactionDirection
  totalAmount     Decimal                      @db.Decimal(12,2)
  totalQty        Int                          @default(0)
  transactionDate DateTime                     @default(now())
  note            String?
  recordedBy      String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  items           SupplierTransactionItem[]

  @@index([supplierId, createdAt])
  @@index([branchId])
  @@map("supplier_transactions")
}

model SupplierTransactionItem {
  id                    Int                  @id @default(autoincrement())
  transactionId         Int
  transaction           SupplierTransaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId             Int
  product               Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot   String
  productSkuSnapshot    String
  quantity              Int
  unitPrice             Decimal              @db.Decimal(10,2)
  lineTotal             Decimal              @db.Decimal(12,2)
  createdAt             DateTime             @default(now())

  @@index([transactionId])
  @@index([productId])
  @@map("supplier_transaction_items")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY
// One record per product. Stock quantity tracked here.
// ─────────────────────────────────────────────────────────────

model Inventory {
  id              Int       @id @default(autoincrement())
  productId       Int
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int       @default(0)
  reservedQty     Int       @default(0)
  lowStockThreshold Int     @default(10)
  reorderPoint    Int       @default(20)
  reorderQuantity Int       @default(50)
  warehouseId     Int
  branch          Branch    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location        String?
  lastCountedAt   DateTime?
  updatedAt       DateTime  @updatedAt

  transactions    InventoryTransaction[]
  transfers       StockTransfer[]

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@map("inventory")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY TRANSACTIONS
// Every stock movement creates an immutable record here.
// ─────────────────────────────────────────────────────────────

model InventoryTransaction {
  id          Int                       @id @default(autoincrement())
  inventoryId Int
  inventory   Inventory                 @relation(fields: [inventoryId], references: [id])
  type        InventoryTransactionType
  quantity    Int
  balanceBefore Int
  balanceAfter  Int
  reference   String?
  notes       String?
  batchName   String?
  manufactureDate DateTime?
  expiryDate  DateTime?
  sizeName    String?    // Snapshot of size for this transaction
  createdAt   DateTime                  @default(now())

  @@map("inventory_transactions")
}

// ─────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique
  customerId      Int?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  processedBy     Int?
  staffUser       User?         @relation("StaffOrders", fields: [processedBy], references: [id])
  channel         OrderChannel  @default(ONLINE)
  status          OrderStatus   @default(PENDING)

  // Shipping
  shippingName    String
  shippingPhone   String
  shippingAddress String
  shippingCity    String
  shippingPostal  String?
  shippingCountry String        @default("Bangladesh")

  // Financials
  subtotal        Decimal       @db.Decimal(12,2)
  discountAmount  Decimal       @default(0) @db.Decimal(12,2)
  shippingCharge  Decimal       @default(0) @db.Decimal(12,2)
  taxAmount       Decimal       @default(0) @db.Decimal(12,2)
  total           Decimal       @db.Decimal(12,2)
  currency        String        @default("BDT")

  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  shippedAt       DateTime?
  deliveredAt     DateTime?

  items           OrderItem[]
  payment         Payment?
  trackingEvents  OrderTrackingEvent[]
  auditLogs       AuditLog[]

  @@index([customerId, createdAt])
  @@index([customerId, status])
  @@map("orders")
}

// ─────────────────────────────────────────────────────────────
// ORDER TRACKING EVENTS
// Timeline entries for customer/staff order tracking views.
// ─────────────────────────────────────────────────────────────

model OrderTrackingEvent {
  id            Int         @id @default(autoincrement())
  orderId       Int         @map("order_id")
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status        OrderStatus
  title         String      @db.VarChar(120)
  description   String?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([orderId])
  @@index([orderId, createdAt])
  @@map("order_tracking_events")
}

// ─────────────────────────────────────────────────────────────
// ORDER ITEMS
// ─────────────────────────────────────────────────────────────

model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     Int
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product   @relation(fields: [productId], references: [id])
  productName String
  productSku  String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10,2)
  totalPrice  Decimal   @db.Decimal(12,2)
  
  return      Return?

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────
// RETURNS
// Track product returns and return reasons.
// ─────────────────────────────────────────────────────────────

model Return {
  id              Int            @id @default(autoincrement())
  orderItemId     Int            @unique
  orderItem       OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  
  reason          ReturnReason
  returnedQuantity Int
  returnedAt      DateTime?
  
  status          ReturnStatus   @default(REQUESTED)
  refundAmount    Decimal        @db.Decimal(12,2)
  refundedAt      DateTime?
  
  notes           String?
  photosUrl       String[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  refund          Refund?

  @@map("returns")
}

// ─────────────────────────────────────────────────────────────
// PAYMENTS
// One payment record per order.
// ─────────────────────────────────────────────────────────────

model Payment {
  id                Int           @id @default(autoincrement())
  orderId           Int           @unique
  order             Order         @relation(fields: [orderId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(12,2)
  currency          String        @default("BDT")

  // SSLCommerz fields
  tranId            String?       @unique
  valId             String?
  bankTranId        String?
  storeAmount       Decimal?      @db.Decimal(12,2)
  cardType          String?
  cardBrand         String?
  ipnPayload        Json?

  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  refunds           Refund[]

  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// REFUNDS
// Track refunds issued for returns and cancellations.
// ─────────────────────────────────────────────────────────────

model Refund {
  id              Int            @id @default(autoincrement())
  returnId        Int?           @unique
  return          Return?        @relation(fields: [returnId], references: [id], onDelete: SetNull)
  paymentId       Int
  payment         Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  originalAmount  Decimal        @db.Decimal(12,2)
  refundAmount    Decimal        @db.Decimal(12,2)
  
  status          String         @default("PENDING")
  gatewayRefId    String?        @unique
  
  processedAt     DateTime?
  failureReason   String?
  createdAt       DateTime       @default(now())
  
  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────────────────────

model Wishlist {
  id          Int       @id @default(autoincrement())
  customerId  Int
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([customerId, productId])
  @@index([customerId, createdAt])
  @@map("wishlist")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOGS
// Immutable log of all significant state changes.
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          Int       @id @default(autoincrement())
  userId      Int?
  user        User?     @relation("CreatedBy", fields: [userId], references: [id])
  action      String
  entity      String
  entityId    Int
  order       Order?    @relation(fields: [entityId], references: [id])
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT ANALYTICS
// Cached product performance metrics for dashboard queries.
// ─────────────────────────────────────────────────────────────

model ProductAnalytics {
  id              Int       @id @default(autoincrement())
  productId       Int       @unique
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  totalSold       Int       @default(0)
  totalRevenue    Decimal   @default(0) @db.Decimal(12,2)
  totalViews      Int       @default(0)
  wishlistCount   Int       @default(0)
  avgRating       Decimal?  @db.Decimal(3,2)
  reviewCount     Int       @default(0)
  returnCount     Int       @default(0)
  lastSoldAt      DateTime?
  lastUpdated     DateTime  @default(now()) @updatedAt

  @@map("product_analytics")
}

// ─────────────────────────────────────────────────────────────
// STOCK TRANSFERS
// Track inter-warehouse stock movements.
// ─────────────────────────────────────────────────────────────

model StockTransfer {
  id              Int                 @id @default(autoincrement())
  productId       Int
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryId     Int
  inventory       Inventory           @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  fromWarehouseId Int?
  toWarehouseId   Int?
  quantity        Int
  status          StockTransferStatus @default(PENDING)
  initiatedBy     Int
  initiatedByUser User                @relation(fields: [initiatedBy], references: [id], onDelete: Restrict)
  initiatedAt     DateTime            @default(now())
  receivedAt      DateTime?
  referenceNumber String?             @unique
  notes           String?

  @@map("stock_transfers")
}

// ─────────────────────────────────────────────────────────────
// BRANCHES (WAREHOUSES / STORES)
// Multi-location management system.
// ─────────────────────────────────────────────────────────────

model Branch {
  id            Int         @id @default(autoincrement())
  name          String      @unique
  branchCode    String      @unique
  branchType    BranchType  @default(WAREHOUSE)
  
  address       String?
  city          String?
  postalCode    String?
  country       String?
  phone         String?
  email         String?
  
  managerName   String?
  managerPhone  String?
  
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userRoles     UserRole_Model[]
  userBranches  UserBranch[]
  inventory     Inventory[]
  categories    Category[]

  @@map("branches")
}

// ─────────────────────────────────────────────────────────────
// ROLES (DYNAMIC, CUSTOMIZABLE)
// System admin can create new roles at runtime.
// ─────────────────────────────────────────────────────────────

model Role {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  description   String?
  
  isSystem      Boolean   @default(false)
  isActive      Boolean   @default(true)
  canBeDeleted  Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userRoles     UserRole_Model[]
  permissions   RolePermission[]

  @@map("roles")
}

// ─────────────────────────────────────────────────────────────
// PERMISSIONS (GRANULAR ACCESS CONTROL)
// Format: RESOURCE.ACTION (e.g., products.read, orders.create)
// ─────────────────────────────────────────────────────────────

model Permission {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  description   String?
  
  resource      String
  action        String
  module        String?
  
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roles         RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────
// ROLE PERMISSIONS (JUNCTION TABLE)
// Links roles to their permissions.
// ─────────────────────────────────────────────────────────────

model RolePermission {
  id            Int       @id @default(autoincrement())
  
  roleId        Int
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  permissionId  Int
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// USER ROLES (MANY-TO-MANY WITH SCOPE)
// Users can have multiple roles, optionally scoped to a branch.
// ─────────────────────────────────────────────────────────────

model UserRole_Model {
  id            Int       @id @default(autoincrement())
  
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  roleId        Int
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  // Optional: Restrict role to specific branch (e.g., Branch Manager for Branch 2)
  branchId      Int?
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  
  assignedAt    DateTime  @default(now())
  assignedBy    Int?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?

  @@unique([userId, roleId, branchId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// USER BRANCHES (BRANCH ASSIGNMENTS)
// Tracks which branches a user has access to.
// ─────────────────────────────────────────────────────────────

model UserBranch {
  id            Int       @id @default(autoincrement())
  
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  branchId      Int
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  isPrimary     Boolean   @default(false)
  assignedAt    DateTime  @default(now())
  isActive      Boolean   @default(true)

  @@unique([userId, branchId])
  @@map("user_branches")
}

// ─────────────────────────────────────────────────────────────
// SKU SETTINGS (AUTO-GENERATION & VALIDATION)
// Manage SKU format and auto-generation rules per category.
// ─────────────────────────────────────────────────────────────

model SKUSetting {
  id                      Int       @id @default(autoincrement())
  
  categoryId              Int       @unique
  category                Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  prefix                  String    @unique
  currentCounter          Int       @default(0)
  
  enableAutoGeneration    Boolean   @default(true)
  isActive                Boolean   @default(true)
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@map("sku_settings")
}

// ─────────────────────────────────────────────────────────────
// SKU HISTORY (AUDIT TRAIL)
// Track all SKU changes for compliance and debugging.
// ─────────────────────────────────────────────────────────────

model SKUHistory {
  id              Int       @id @default(autoincrement())
  
  productId       Int
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  oldSku          String?
  newSku          String
  changeReason    String?
  changedBy       Int?
  changedAt       DateTime  @default(now())

  @@map("sku_history")
}

// ─────────────────────────────────────────────────────────────
// ROLE ASSIGNMENT (TRACKING)
// Log of role assignments for audit trail.
// ─────────────────────────────────────────────────────────────

model RoleAssignment {
  id              Int       @id @default(autoincrement())
  
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  roleId          Int
  actionType      String    // ASSIGNED, REMOVED, UPDATED
  
  assignedAt      DateTime  @default(now())
  changedBy       Int?
  reason          String?

  @@map("role_assignments")
}

// ─────────────────────────────────────────────────────────────
// APP MODULES
// System modules for navigation and access control
// ─────────────────────────────────────────────────────────────

model AppModule {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  icon        String?
  badge       String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  
  userModules UserModule[]
  @@map("app_modules")
}

model UserModule {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    Int
  module      AppModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isActive    Boolean   @default(true)
  
  @@unique([userId, moduleId])
  @@map("user_modules")
}

// ─────────────────────────────────────────────────────────────
// HOMEPAGE STATS
// Dynamic metrics displayed on the homepage hero section.
// ─────────────────────────────────────────────────────────────

model HomepageStats {
  id                    Int       @id @default(autoincrement())
  
  // Hero section metrics
  totalHappyCustomers   Int       @default(0)
  
  // Free Delivery
  minFreeDeliveryAmount Int       @default(999) // In taka
  isFreeDeliveryActive  Boolean   @default(true)
  
  // Delivery timeframe
  deliveryTimeframe     String    @default("48hr") // e.g., "48hr", "2 days"
  
  // Marketing & promotional - Offer
  currentOfferText      String    @default("Spring Sale - Save up to 40%")
  currentOfferPercentage Int      @default(40) // Max discount %
  isOfferActive         Boolean   @default(true)
  
  // Metadata
  lastUpdated           DateTime  @default(now()) @updatedAt
  
  @@map("homepage_stats")
}

// ─────────────────────────────────────────────────────────────
// SITE SETTINGS
// Global site configuration (store name, hero heading, etc).
// ─────────────────────────────────────────────────────────────

model SiteSettings {
  id                    Int       @id @default(autoincrement())
  
  // Store branding
  storeName             String    @default("Mouchak Cosmetics")
  tagline               String    @default("Clean · Cruelty-Free · Bangladesh")
  primaryColor          String    @default("#f01172")
  
  // Hero section
  heroHeadline          String    @default("Spring Beauty Collection") // e.g., "Summer Collection", "Winter Edition"
  heroYear              String    @default("2026")
  heroDescription       String    @default("Discover luxurious skincare and makeup that celebrates your natural glow. Clean, cruelty-free formulas delivered across Bangladesh in 48 hours.")
  
  // Metadata
  lastUpdated           DateTime  @default(now()) @updatedAt
  
  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────
// HERO SLIDER
// Manage carousel/slider images for the hero section.
// ─────────────────────────────────────────────────────────────

model HeroSlider {
  id            Int       @id @default(autoincrement())
  title         String?
  description   String?
  imageUrl      String    @db.Text
  imageAlt      String    @default("Hero slider image")
  
  // Marketing & Navigation
  buttonText    String?
  buttonLink    String?
  
  // Display control
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  
  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([displayOrder, isActive])
  @@map("hero_slider")
}

// ─────────────────────────────────────────────────────────────
// PROMOTIONS
// Manage discount promotions displayed on the storefront.
// ─────────────────────────────────────────────────────────────

model Promotion {
  id            Int       @id @default(autoincrement())
  label         String                          // e.g. "Eid Flash Sale"
  banner        String                          // Banner text shown on homepage
  pct           Int                             // Discount percentage (1-95)
  endsAt        String?                         // Human-readable end label, e.g. "Apr 30"
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("promotions")
}


