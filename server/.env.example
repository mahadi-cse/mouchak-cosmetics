# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/mouchak_db

# ── Auth ──────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=replace-with-32-plus-char-secret
ACCESS_TOKEN_EXPIRES_HOURS=3
REFRESH_TOKEN_EXPIRES_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=mouchak_refresh_token

# Google OAuth token verification (must match client Google OAuth app)
GOOGLE_CLIENT_ID=

# ── Keycloak ──────────────────────────────────────────────
KEYCLOAK_REALM_URL=http://localhost:8080/realms/mouchak
KEYCLOAK_CLIENT_ID=mouchak-backend
KEYCLOAK_CLIENT_SECRET=your-secret-here
# JWKS endpoint is derived: ${KEYCLOAK_REALM_URL}/protocol/openid-connect/certs

# ── SSLCommerz ────────────────────────────────────────────
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWD=qwerty
SSLCOMMERZ_IS_LIVE=false

# Success/fail/cancel/IPN redirect URLs sent to SSLCommerz
SSLCOMMERZ_SUCCESS_URL=http://localhost:4000/api/payments/sslcommerz/success
SSLCOMMERZ_FAIL_URL=http://localhost:4000/api/payments/sslcommerz/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:4000/api/payments/sslcommerz/cancel
SSLCOMMERZ_IPN_URL=http://localhost:4000/api/payments/sslcommerz/ipn

# ── File Uploads (optional — local disk by default) ───────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Misc ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
LOG_LEVEL=debug
TZ=Asia/Dhaka
